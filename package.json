{
  "name": "corner-click",
  "version": "1.0.11",
  "allowScripts": {
    "@firebase/util@1.15.1": true,
    "esbuild@0.28.1": true,
    "protobufjs@7.6.4": true,
    "re2@1.24.1": true,
    "sharp@0.34.5": true
  },
  "dependencies": {
    "@rolldown/pluginutils": "^1.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@testing-library/dom": "^10.4.1",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "@webcontainer/env": "^1.1.1",
    "cross-env": "^7.0.3",
    "firebase-tools": "^13.10.0",
    "prettier": "^3.0.0",
    "prettier-plugin-astro": "^0.14.1",
    "syncpack": "^15.3.2",
    "turbo": "^2.10.0",
    "vitest": "^4.1.9"
  },
  "packageManager": "npm@11.9.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:e2e": "cross-env PUBLIC_USE_EMULATOR=true USE_FIREBASE_EMULATOR=true firebase emulators:exec --project demo-corner-click \"turbo run dev\"",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "lint:deps": "syncpack lint && syncpack format --check",
    "lint:fix": "biome lint --write .",
    "start:api": "node apps/api/dist/index.js",
    "sync-deps": "syncpack fix && syncpack format",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npm run test -w apps-e2e",
    "test:ui": "vitest --ui",
    "test:watch": "vitest"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
