{
  "name": "corner-click",
  "version": "1.0.3",
  "devDependencies": {
    "prettier": "^3.0.0",
    "syncpack": "^15.3.2",
    "turbo": "^2.0.0"
  },
  "overrides": {
    "jose": "4.15.5"
  },
  "packageManager": "npm@11.9.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,astro}\"",
    "lint": "turbo run lint",
    "lint:deps": "syncpack lint && syncpack format --check",
    "sync-deps": "syncpack fix && syncpack format"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
