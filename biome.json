{
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": false,
    "includes": ["**/*", "!coverage/**"]
  },
  "formatter": {
    "enabled": true,
    "formatWithErrors": false,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "a11y": {
        "preset": "recommended",
        "noSvgWithoutTitle": "warn",
        "useButtonType": "warn",
        "noStaticElementInteractions": "warn",
        "useKeyWithClickEvents": "warn",
        "noAutofocus": "warn",
        "useGenericFontNames": "warn"
      },
      "complexity": {
        "preset": "recommended",
        "noUselessConstructor": "warn"
      },
      "correctness": {
        "preset": "recommended",
        "useExhaustiveDependencies": "warn",
        "noInnerDeclarations": "warn",
        "noInvalidPositionAtImportRule": "warn",
        "useHookAtTopLevel": "warn"
      },
      "performance": {
        "preset": "recommended"
      },
      "security": {
        "preset": "recommended"
      },
      "style": {
        "preset": "recommended",
        "useBlockStatements": "warn",
        "noNonNullAssertion": "warn",
        "useConst": "warn"
      },
      "suspicious": {
        "preset": "recommended",
        "noExplicitAny": "warn",
        "noArrayIndexKey": "warn",
        "noAssignInExpressions": "warn",
        "noDuplicateProperties": "warn",
        "noImplicitAnyLet": "warn",
        "noRedeclare": "warn",
        "useIterableCallbackReturn": "warn"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "double",
      "semicolons": "asNeeded",
      "trailingCommas": "es5"
    }
  },
  "json": {
    "formatter": {
      "enabled": true
    }
  },
  "css": {
    "parser": {
      "cssModules": false,
      "tailwindDirectives": true
    }
  }
}
